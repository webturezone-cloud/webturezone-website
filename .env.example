# n8n — contact form POST (optional override; default URL is set in lib/contactSubmission.ts)
# NEXT_PUBLIC_CONTACT_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/...

# Supabase — optional duplicate save when URL + key are set
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use either the dashboard “publishable” key (newer projects) or legacy anon key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
